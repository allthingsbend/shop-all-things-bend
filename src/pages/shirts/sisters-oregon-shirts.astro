---
const pageTitle = "Sisters Oregon Shirts | Sisters, OR T-Shirts and Local Apparel";
const pageDescription = "Shop Sisters, Oregon shirts inspired by the Three Sisters, mountain views, small-town charm, and Central Oregon adventure.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://shop.allthingsbend.org/shirts/sisters-oregon-shirts" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://shop.allthingsbend.org/shirts/sisters-oregon-shirts" />

    <style>
      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #faf7ef;
        color: #2f2a24;
        line-height: 1.6;
      }

      header {
        padding: 24px;
        background: #234437;
        color: white;
      }

      header a {
        color: white;
        text-decoration: none;
      }

      nav {
        margin-top: 12px;
      }

      nav a {
        margin-right: 16px;
      }

      main {
        padding: 40px 24px;
        max-width: 900px;
        margin: auto;
      }

      h1 {
        font-size: 42px;
        line-height: 1.1;
        margin-bottom: 16px;
      }

      h2 {
        margin-top: 36px;
      }

      .button {
        display: inline-block;
        margin-top: 20px;
        padding: 14px 22px;
        background: #234437;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: bold;
      }

      a {
        color: #234437;
      }

      .card {
        background: white;
        padding: 24px;
        border-radius: 14px;
        margin-top: 24px;
        border: 1px solid #eee3d2;
      }
    </style>
  </head>

  <body>
    <header>
      <a href="/">All Things Bend Shop</a>
      <nav>
        <a href="/mugs/bend-oregon-mugs">Mugs</a>
        <a href="/shirts/bend-oregon-shirts">Shirts</a>
        <a href="/stickers/bend-oregon-stickers">Stickers</a>
      </nav>
    </header>

    <main>
      <h1>Sisters Oregon Shirts</h1>

      <p>Shop shirts inspired by Sisters, Oregon, from mountain views and pine forests to small-town charm and Central Oregon road trips.</p>

      <div class="card">
        <h2>Sisters-inspired apparel</h2>
        <p>These shirts are a simple way to carry the Sisters vibe with you, whether you love hiking, camping, scenic drives, or the quiet charm of this mountain town.</p>

        <a class="button" href="https://allthingsbend.etsy.com" target="_blank" rel="noopener noreferrer">
          Shop Sisters Shirts on Etsy
        </a>
      </div>

      <h2>Related collections</h2>
      <ul>
        <li><a href="/mugs/sisters-oregon-mugs">Sisters Oregon Mugs</a></li>
        <li><a href="/stickers/sisters-oregon-stickers">Sisters Oregon Stickers</a></li>
        <li><a href="/shirts/bend-oregon-shirts">Bend Oregon Shirts</a></li>
      </ul>
    </main>
  </body>
</html>
