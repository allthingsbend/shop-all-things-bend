---
import Layout from '../../layouts/Layout.astro';

const pageTitle = "Bend Oregon Shirts | Bend Oregon T Shirts & Apparel";
const pageDescription = "Shop Bend Oregon shirts and t shirts inspired by Mt. Bachelor, Central Oregon, mountain life, coffee culture, hiking, skiing, and outdoor adventures.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
>
  <section class="hero">
    <div class="hero-inner">
      <div class="eyebrow">Bend Oregon shirts</div>

      <h1>Bend Oregon Shirts & T Shirts</h1>

      <p>
        Shop Bend Oregon shirts inspired by mountain towns, Central Oregon
        adventures, local coffee culture, ski mornings, hiking trails, river
        days, and the laid-back Bend lifestyle.
      </p>

      <div class="hero-buttons">
        <a
          class="button"
          href="https://allthingsbend.etsy.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          Shop on Etsy
        </a>

        <a
          class="button secondary"
          href="/mugs/bend-oregon-mugs/"
        >
          Browse Mugs
        </a>
      </div>
    </div>
  </section>

  <main>
    <section class="intro">
      <h2>Bend Oregon T Shirts Inspired by Central Oregon</h2>

      <p>
        These Bend Oregon t shirts are designed around the places, activities,
        and everyday moments that make Bend unique. Think coffee before Mt.
        Bachelor, hiking near Smith Rock, river days on the Deschutes, and
        weekends exploring Central Oregon.
      </p>

      <p>
        Whether you live in Bend, visit every year, or simply love mountain
        towns and the Pacific Northwest, these shirts are made to feel simple,
        comfortable, local, and easy to wear.
      </p>
    </section>

    <section class="grid">
      <div class="card">
        <h3>Mt. Bachelor & Ski Inspired Shirts</h3>

        <p>
          Bend Oregon shirts inspired by powder mornings, ski culture, mountain
          views, and coffee before heading up to Mt. Bachelor.
        </p>
      </div>

      <div class="card">
        <h3>Minimalist Bend Oregon Apparel</h3>

        <p>
          Clean and simple Bend t shirt designs inspired by outdoor living,
          Central Oregon landscapes, and everyday local life.
        </p>
      </div>

      <div class="card">
        <h3>Outdoor & Adventure Inspired Shirts</h3>

        <p>
          Apparel inspired by hiking, camping, paddleboarding, river days,
          breweries, coffee shops, and weekends exploring Bend.
        </p>
      </div>
    </section>

    <section class="intro">
      <h2>Why Bend Oregon Shirts Make Great Gifts</h2>

      <p>
        Bend Oregon t shirts make great gifts for locals, former locals,
        travelers, outdoor lovers, hikers, skiers, campers, coffee lovers, and
        anyone connected to Central Oregon.
      </p>

      <p>
        They work well as souvenirs, birthday gifts, holiday gifts, or simple
        everyday shirts inspired by Bend.
      </p>
    </section>

    <section class="card">
      <h2>Shop Bend Oregon Apparel on Etsy</h2>

      <p>
        Browse the latest Bend-inspired shirt designs in the All Things Bend
        Etsy shop. New apparel designs may include mountain themes, local
        sayings, minimalist artwork, coffee-inspired graphics, and outdoor
        inspired Central Oregon apparel.
      </p>

      <a
        class="button"
        href="https://allthingsbend.etsy.com"
        target="_blank"
        rel="noopener noreferrer"
      >
        View Bend Oregon T Shirts
      </a>
    </section>

    <section class="intro">
      <h2>Related Bend Oregon Collections</h2>

      <div class="grid">
        <div class="card">
          <h3>Bend Oregon Mugs</h3>

          <p>
            Coffee mugs inspired by Bend mornings, Mt. Bachelor, Smith Rock,
            and Central Oregon adventures.
          </p>

          <a href="/mugs/bend-oregon-mugs/">
            View collection
          </a>
        </div>

        <div class="card">
          <h3>Bend Oregon Stickers</h3>

          <p>
            Stickers inspired by coffee, mountains, skiing, camping, and Bend.
          </p>

          <a href="/stickers/bend-oregon-stickers/">
            View collection
          </a>
        </div>

        <div class="card">
          <h3>Sisters Oregon Shirts</h3>

          <p>
            Local-inspired shirt designs connected to Sisters, Oregon and the
            Three Sisters.
          </p>

          <a href="/shirts/sisters-oregon-shirts/">
            View collection
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
