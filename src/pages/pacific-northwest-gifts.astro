---
import Layout from '../../layouts/Layout.astro';

const pageTitle = "Gifts for Hikers | All Things Bend Shop";
const pageDescription = "Shop gifts for hikers inspired by Bend Oregon hiking trails, mountain adventures, camping, and Pacific Northwest outdoor life.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
>
  <section class="hero">
    <div class="hero-inner">
      <div class="eyebrow">All Things Bend Shop</div>

      <h1>Gifts for Hikers</h1>

      <p>
        Discover hiking-inspired gifts connected to Bend trails, mountain adventures, camping weekends, and life outdoors in Central Oregon.
      </p>

      <div class="hero-buttons">
        <a
          class="button"
          href="https://allthingsbend.etsy.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          Shop on Etsy
        </a>

        <a
          class="button secondary"
          href="/mugs/bend-oregon-mugs/"
        >
          Browse Mugs
        </a>
      </div>
    </div>
  </section>

  <main>
    <section class="intro">
      <h2>Outdoor Gifts Inspired by Hiking and Adventure</h2>

      <p>
        These gifts are designed for hikers, backpackers, outdoor lovers, campers, and anyone who enjoys spending time outside in the Pacific Northwest.
      </p>

      <p>
        Popular ideas include hiking shirts, mountain mugs, outdoor stickers, and simple everyday gear inspired by Bend and Central Oregon.
      </p>
    </section>

    <section class="grid">
      <div class="card">
        <h3>Local Inspired Designs</h3>

        <p>
          Designs inspired by Bend, Central Oregon, mountain towns,
          coffee culture, skiing, hiking, and outdoor adventures.
        </p>
      </div>

      <div class="card">
        <h3>Simple Everyday Gifts</h3>

        <p>
          Easy gift ideas for birthdays, holidays, vacations,
          housewarming gifts, and outdoor lovers.
        </p>
      </div>

      <div class="card">
        <h3>Central Oregon Lifestyle</h3>

        <p>
          Products inspired by mountain mornings, local coffee,
          camping trips, ski weekends, and Pacific Northwest living.
        </p>
      </div>
    </section>

    <section class="card">
      <h2>Shop Gifts for Hikers on Etsy</h2>

      <p>
        Browse the latest designs and products in the All Things Bend Etsy shop,
        including mugs, shirts, stickers, and Central Oregon inspired gifts.
      </p>

      <a
        class="button"
        href="https://allthingsbend.etsy.com"
        target="_blank"
        rel="noopener noreferrer"
      >
        View Collection
      </a>
    </section>

    <section class="intro">
      <h2>Related Collections</h2>

      <div class="grid">
        <div class="card">
          <h3>Bend Oregon Mugs</h3>

          <p>
            Coffee mugs inspired by Bend mornings, Mt. Bachelor,
            Smith Rock, and Central Oregon adventures.
          </p>

          <a href="/mugs/bend-oregon-mugs/">
            View collection
          </a>
        </div>

        <div class="card">
          <h3>Bend Oregon Shirts</h3>

          <p>
            Outdoor-inspired Bend apparel designed around mountain town life.
          </p>

          <a href="/shirts/bend-oregon-shirts/">
            View collection
          </a>
        </div>

        <div class="card">
          <h3>Bend Oregon Stickers</h3>

          <p>
            Stickers inspired by coffee, mountains, skiing,
            hiking, camping, and Bend.
          </p>

          <a href="/stickers/bend-oregon-stickers/">
            View collection
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
