---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="All Things Bend Shop | Bend Oregon Gifts, Mugs, Shirts and Stickers"
  description="Shop Bend and Central Oregon inspired mugs, shirts, stickers, and gifts from All Things Bend."
>
  <section class="hero">
    <div class="hero-inner">
      <div class="eyebrow">Bend and Central Oregon gifts</div>
      <h1>Local-inspired mugs, shirts, stickers, and gifts.</h1>
      <p>Simple, outdoorsy designs inspired by Bend, Sisters, Smith Rock, mountain mornings, coffee stops, ski days, and Central Oregon life.</p>

      <div class="hero-buttons">
        <a class="button" href="/mugs/bend-oregon-mugs/">Shop Bend Mugs</a>
        <a class="button secondary" href="/stickers/bend-oregon-stickers/">Shop Stickers</a>
      </div>
    </div>
  </section>

  <main>
    <section class="intro">
      <h2>Shop local-inspired collections</h2>
      <p>Start with Bend and Sisters designs, with more Central Oregon collections coming soon.</p>
    </section>

    <section class="grid">
      <div class="card">
        <h3>Bend Oregon Mugs</h3>
        <p>Coffee mugs inspired by Bend mornings and mountain adventures.</p>
        <a href="/mugs/bend-oregon-mugs/">View collection</a>
      </div>

      <div class="card">
        <h3>Sisters Oregon Mugs</h3>
        <p>Mugs inspired by Sisters, Oregon and the Three Sisters.</p>
        <a href="/mugs/sisters-oregon-mugs/">View collection</a>
      </div>

      <div class="card">
        <h3>Bend Oregon Shirts</h3>
        <p>Local-inspired shirts for Bend lovers.</p>
        <a href="/shirts/bend-oregon-shirts/">View collection</a>
      </div>

      <div class="card">
        <h3>Sisters Oregon Shirts</h3>
        <p>Simple apparel inspired by Sisters and Central Oregon.</p>
        <a href="/shirts/sisters-oregon-shirts/">View collection</a>
      </div>

      <div class="card">
        <h3>Bend Oregon Stickers</h3>
        <p>Stickers inspired by Bend, Smith Rock, coffee, and the outdoors.</p>
        <a href="/stickers/bend-oregon-stickers/">View collection</a>
      </div>

      <div class="card">
        <h3>Sisters Oregon Stickers</h3>
        <p>Stickers inspired by Sisters, Oregon and mountain town life.</p>
        <a href="/stickers/sisters-oregon-stickers/">View collection</a>
      </div>
    </section>
  </main>
</Layout>
