---
import Layout from '../../layouts/Layout.astro';

const pageTitle = "Bend Oregon Mugs | Bend Oregon Coffee Mugs & Gifts";
const pageDescription = "Shop Bend Oregon mugs and coffee cups inspired by Mt. Bachelor, Smith Rock, the Cascade Mountains, local coffee, and Central Oregon adventures.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
>
  <section class="hero">
    <div class="hero-inner">
      <div class="eyebrow">Bend Oregon mugs</div>

      <h1>Bend Oregon Coffee Mugs & Gifts</h1>

      <p>
        Shop Bend Oregon mugs inspired by mountain mornings, local coffee,
        Mt. Bachelor ski days, Smith Rock views, the Deschutes River, and
        everyday life in Central Oregon.
      </p>

      <div class="hero-buttons">
        <a
          class="button"
          href="https://allthingsbend.etsy.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          Shop on Etsy
        </a>

        <a
          class="button secondary"
          href="/stickers/bend-oregon-stickers/"
        >
          Browse Stickers
        </a>
      </div>
    </div>
  </section>

  <main>
    <section class="intro">
      <h2>Bend Oregon Coffee Mugs Inspired by Central Oregon</h2>

      <p>
        Our Bend Oregon coffee mugs are inspired by the outdoors, local coffee
        culture, ski mornings, camping trips, Cascade views, and everyday life
        in Bend and Central Oregon.
      </p>

      <p>
        Whether you live in Bend, used to live here, visit every year, or just
        love Central Oregon, these mugs are designed to feel simple, local,
        useful, and giftable.
      </p>
    </section>

    <section class="grid">
      <div class="card">
        <h3>Mt. Bachelor Coffee Mugs</h3>

        <p>
          Bend mugs inspired by snowy drives, ski mornings, and coffee before
          heading up to Mt. Bachelor.
        </p>
      </div>

      <div class="card">
        <h3>Smith Rock & High Desert Designs</h3>

        <p>
          Coffee cups inspired by Central Oregon scenery, desert colors, rock
          formations, and local outdoor culture.
        </p>
      </div>

      <div class="card">
        <h3>Bend Souvenir Mugs</h3>

        <p>
          A practical Bend Oregon souvenir for visitors, locals, coffee lovers,
          and anyone connected to Central Oregon.
        </p>
      </div>
    </section>

    <section class="intro">
      <h2>Why These Bend Oregon Mugs Make Great Gifts</h2>

      <p>
        A Bend Oregon mug is a simple gift that feels personal. They work well
        for skiers, hikers, campers, river lovers, coffee drinkers, and anyone
        who loves Bend and the Pacific Northwest lifestyle.
      </p>

      <p>
        These mugs are especially popular for birthdays, holidays,
        housewarming gifts, thank-you gifts, and Bend vacation souvenirs.
      </p>
    </section>

    <section class="card">
      <h2>Shop Bend Mugs on Etsy</h2>

      <p>
        Browse the latest Bend-inspired mug designs in the All Things Bend Etsy
        shop. New designs may include local sayings, mountain-inspired artwork,
        minimalist Bend designs, and coffee mugs made for people who love
        Central Oregon.
      </p>

      <a
        class="button"
        href="https://allthingsbend.etsy.com"
        target="_blank"
        rel="noopener noreferrer"
      >
        View Bend Oregon Coffee Mugs
      </a>
    </section>

    <section class="intro">
      <h2>Related Bend Oregon Gift Collections</h2>

      <div class="grid">
        <div class="card">
          <h3>Bend Oregon Shirts</h3>

          <p>
            Local-inspired shirts designed around Bend, Oregon and outdoor life.
          </p>

          <a href="/shirts/bend-oregon-shirts/">
            View collection
          </a>
        </div>

        <div class="card">
          <h3>Bend Oregon Stickers</h3>

          <p>
            Stickers inspired by coffee, mountains, skiing, camping, and Bend.
          </p>

          <a href="/stickers/bend-oregon-stickers/">
            View collection
          </a>
        </div>

        <div class="card">
          <h3>Sisters Oregon Mugs</h3>

          <p>
            Mug designs inspired by Sisters, Oregon and the Three Sisters.
          </p>

          <a href="/mugs/sisters-oregon-mugs/">
            View collection
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
