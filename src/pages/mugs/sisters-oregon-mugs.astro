        border-radius: 8px;
        font-weight: bold;
      }

      a {
        color: #234437;
      }

      .card {
        background: white;
        padding: 24px;
        border-radius: 14px;
        margin-top: 24px;
        border: 1px solid #eee3d2;
      }
    </style>
  </head>

  <body>
    <header>
      <a href="/">All Things Bend Shop</a>
