---
import Layout from '../../layouts/Layout.astro';

const pageTitle = "Bend Oregon Gifts | All Things Bend Shop";
const pageDescription = "Shop Bend Oregon gifts inspired by mountain towns, skiing, hiking, coffee culture, and Central Oregon adventures.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
>
  <section class="hero">
    <div class="hero-inner">
      <div class="eyebrow">All Things Bend Shop</div>

      <h1>Bend Oregon Gifts</h1>

      <p>
        Discover Bend Oregon gifts inspired by mountain mornings, ski weekends, coffee shops, hiking trails, camping trips, and the laid-back Central Oregon lifestyle.
      </p>

      <div class="hero-buttons">
        <a
          class="button"
          href="https://allthingsbend.etsy.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          Shop on Etsy
        </a>

        <a
          class="button secondary"
          href="/mugs/bend-oregon-mugs/"
        >
          Browse Mugs
        </a>
      </div>
    </div>
  </section>

  <main>
    <section class="intro">
      <h2>Gift Ideas Inspired by Bend and Central Oregon</h2>

      <p>
        These Bend Oregon gifts are designed for locals, visitors, outdoor lovers, coffee drinkers, skiers, hikers, and anyone who loves Central Oregon.
      </p>

      <p>
        Popular products include Bend mugs, shirts, stickers, and mountain-inspired gifts connected to Mt. Bachelor, Smith Rock, and everyday Bend life.
      </p>
    </section>

    <section class="grid">
      <div class="card">
        <h3>Local Inspired Designs</h3>

        <p>
          Designs inspired by Bend, Central Oregon, mountain towns,
          coffee culture, skiing, hiking, and outdoor adventures.
        </p>
      </div>

      <div class="card">
        <h3>Simple Everyday Gifts</h3>

        <p>
          Easy gift ideas for birthdays, holidays, vacations,
          housewarming gifts, and outdoor lovers.
        </p>
      </div>

      <div class="card">
        <h3>Central Oregon Lifestyle</h3>

        <p>
          Products inspired by mountain mornings, local coffee,
          camping trips, ski weekends, and Pacific Northwest living.
        </p>
      </div>
    </section>

    <section class="card">
      <h2>Shop Bend Oregon Gifts on Etsy</h2>

      <p>
        Browse the latest designs and products in the All Things Bend Etsy shop,
        including mugs, shirts, stickers, and Central Oregon inspired gifts.
      </p>

      <a
        class="button"
        href="https://allthingsbend.etsy.com"
        target="_blank"
        rel="noopener noreferrer"
      >
        View Collection
      </a>
    </section>

    <section class="intro">
      <h2>Related Collections</h2>

      <div class="grid">
        <div class="card">
          <h3>Bend Oregon Mugs</h3>

          <p>
            Coffee mugs inspired by Bend mornings, Mt. Bachelor,
            Smith Rock, and Central Oregon adventures.
          </p>

          <a href="/mugs/bend-oregon-mugs/">
            View collection
          </a>
        </div>

        <div class="card">
          <h3>Bend Oregon Shirts</h3>

          <p>
            Outdoor-inspired Bend apparel designed around mountain town life.
          </p>

          <a href="/shirts/bend-oregon-shirts/">
            View collection
          </a>
        </div>

        <div class="card">
          <h3>Bend Oregon Stickers</h3>

          <p>
            Stickers inspired by coffee, mountains, skiing,
            hiking, camping, and Bend.
          </p>

          <a href="/stickers/bend-oregon-stickers/">
            View collection
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
